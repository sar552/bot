# ===== Database =====
DATABASE_URL=postgresql+asyncpg://penbot:penbot@db:5432/penbot
REDIS_URL=redis://redis:6379/0

# ===== Google Sheets (ixtiyoriy — bo'sh bo'lsa o'chiriladi) =====
